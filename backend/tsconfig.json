{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJs",
    "moduleResolution": "bundler",

    "rootDir": "./src",
    "outDir": "./dist",

    "strict": false,

    "esModuleInterop": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,

    "skipLibCheck": true
  },

  "include": ["src"]
}